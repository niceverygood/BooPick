# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic Claude (자연어 파싱 + 산업 관점 분석)
ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────
# KakaoPay (서버 전용 — 절대 NEXT_PUBLIC_ 접두사 금지)
# 가맹점 어드민(https://online.developers.kakao.com/) 에서 발급
# ─────────────────────────────────────────────

# Secret key (서버에서 API 호출 시 Authorization 헤더)
#   채팅·코드·문서 어디에도 평문 노출 금지. 노출 시 즉시 재발급.
KAKAOPAY_SECRET_KEY=

# CID (가맹점 코드)
#   테스트: 단건 TC0ONETIME, 정기 TCSUBSCRIP
#   운영: 가맹점 어드민에서 발급. 정기결제는 별도 신청 필요.
KAKAOPAY_CID_ONETIME=TC0ONETIME
KAKAOPAY_CID_SUBSCRIPTION=TCSUBSCRIP

# 콜백 도메인 (카카오페이가 redirect 할 base URL)
#   로컬:  http://localhost:3000
#   운영:  https://boo-pick.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# (선택) Vercel 자동 감지되므로 명시 불필요
# VERCEL=1
