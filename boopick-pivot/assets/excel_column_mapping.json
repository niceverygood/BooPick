{
  "_comment": "네이버부동산 표준 엑셀 헤더 → BooPick 표준 컬럼 매핑. 사용자 업로드 시 자동 매핑에 사용.",

  "column_mappings": {
    "article_no": {
      "aliases": ["매물번호", "매물 번호", "article_no", "no", "번호"],
      "type": "string",
      "note": "엑셀 셀이 =HYPERLINK() 함수로 들어있는 경우, URL의 articleNo= 파라미터에서 추출"
    },
    "공급_m2": {
      "aliases": ["공급/계약/대지", "공급", "계약면적", "공급면적", "계약/공급"],
      "type": "number",
      "unit": "㎡",
      "note": "결정 케이스에서 가장 자주 혼동되는 컬럼. 평이 아닌 ㎡ 단위. 사용자에게 단위 확인 필수."
    },
    "전용_m2": {
      "aliases": ["전용/연", "전용", "전용면적"],
      "type": "number",
      "unit": "㎡"
    },
    "해당층": {
      "aliases": ["해당층", "층"],
      "type": "string"
    },
    "전체층": {
      "aliases": ["전체층", "총층", "건물층"],
      "type": "string"
    },
    "보증금": {
      "aliases": ["전세금", "보증금", "전세"],
      "type": "number",
      "unit": "원"
    },
    "월세": {
      "aliases": ["월세", "임대료"],
      "type": "number",
      "unit": "원"
    },
    "관리비": {
      "aliases": ["관리비"],
      "type": "number",
      "unit": "원",
      "note": "네이버부동산 데이터에 별도 관리비 컬럼 없을 수 있음. 광고 본문(설명)에서 정규식으로 추출 권장."
    },
    "현재업종": {
      "aliases": ["현재업종", "현재 업종"],
      "type": "string"
    },
    "추천업종": {
      "aliases": ["추천업종", "추천 업종"],
      "type": "string"
    },
    "간략설명": {
      "aliases": ["간략설명", "제목", "타이틀"],
      "type": "string",
      "note": "매물 광고 헤드라인. 검색 키워드 매칭에 핵심."
    },
    "설명": {
      "aliases": ["설명", "상세설명", "본문", "상세"],
      "type": "string",
      "note": "광고 풀 본문. 주차·관리비·인테리어 등 부가 정보 추출 대상."
    },
    "주소": {
      "aliases": ["주소", "소재지", "위치"],
      "type": "string"
    },
    "사용승인일": {
      "aliases": ["사용승인일", "준공일", "준공", "승인일"],
      "type": "date"
    },
    "중개사무소명": {
      "aliases": ["중개사무소명", "부동산", "중개사", "부동산명"],
      "type": "string"
    }
  },

  "auto_extraction_rules": {
    "_comment": "엑셀에 컬럼 없는 경우, 광고 본문(설명)에서 정규식으로 추출",

    "관리비_from_설명": {
      "patterns": [
        "관리비\\s*([\\d,]+)\\s*만",
        "월\\s*관리\\s*([\\d,]+)\\s*만",
        "관리비\\s*포함",
        "월관\\s*([\\d,]+)\\s*만"
      ],
      "note": "광고 미기재 매물이 약 51%. 추출 못 하면 NULL 저장."
    },
    "주차_from_설명": {
      "patterns": [
        "자주식\\s*(\\d+)\\s*대",
        "기계식\\s*(\\d+)\\s*대",
        "주차\\s*(\\d+)\\s*대"
      ],
      "note": "주차 정보는 listings 테이블에 별도 컬럼으로 저장하지 않고, raw_data jsonb에 보관."
    },
    "지역_from_설명": {
      "patterns": [
        "삼성역", "삼성동", "선릉역", "선정릉역", "역삼역",
        "강남역", "청담동", "논현동", "신사동"
      ],
      "note": "본문에 등장하는 첫 지역명을 listings.지역 으로 저장."
    }
  },

  "validation": {
    "min_required_columns": ["공급_m2", "월세", "사용승인일"],
    "warning_thresholds": {
      "missing_article_no": 0.3,
      "missing_관리비": 0.6
    }
  }
}
